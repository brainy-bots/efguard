# Sui RPC endpoint (testnet or mainnet)
VITE_SUI_RPC_URL=https://fullnode.testnet.sui.io

# Sui network identifier (testnet | mainnet)
VITE_NETWORK=testnet

# Deployed package IDs
VITE_EFGUARD_PACKAGE_ID=0x...
VITE_WORLD_PACKAGE_ID=0x...

# Optional: pre-set the binding ID so the DApp opens directly to a specific base
VITE_DEFAULT_BINDING_ID=

# Optional: EVE Frontier game metadata API for resolving tribe/character names
VITE_DATAHUB_API_URL=https://datahub.evefrontier.com
